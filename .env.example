# AI Content Factory — copy to .env and set values
OPENAI_API_KEY=sk-...
# Local (fără Docker): SQLite. Cu Docker: Postgres.
# DATABASE_URL=sqlite:///./content_factory.db
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_content_factory
REDIS_URL=redis://redis:6379/0
REDIS_CELERY_BROKER=redis://redis:6379/1
REDIS_CELERY_RESULT=redis://redis:6379/2

# Optional: stock media (ShortsGenerator-style scene images)
# PEXELS_API_KEY=your_pexels_key
# enable_stock_media=true

# Optional: external text-to-video API (Open-Sora / Sora-2-Generator style)
# VIDEO_GENERATION_BACKEND=external_api
# VIDEO_API_URL=http://localhost:8001/generate
